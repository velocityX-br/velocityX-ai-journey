# =============================================================================
# sci-ai-mcp — environment variable template
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# GitHub Enterprise (github.wdf.sap.corp)
# -----------------------------------------------------------------------------
# Personal access token with read:repo scope on github.wdf.sap.corp.
# SCI_MCP_GITHUB_TOKEN takes priority; GITHUB_TOKEN is the fallback.
#
# NOTE: This is a PLACEHOLDER. Replace with a real SAP GitHub Enterprise PAT
# before running ingestion (`ingest-docs`). The MCP server itself boots and
# serves cached vectors without it.
GITHUB_TOKEN=your-sap-github-enterprise-pat-here
# SCI_MCP_GITHUB_TOKEN=your-sap-github-enterprise-pat-here

# GitHub API base URL — defaults to SAP GitHub Enterprise.
# The documentation sources live on github.wdf.sap.corp, so the base URL
# defaults to the Enterprise API v3 endpoint (not github.com).
GITHUB_BASE_URL=https://github.wdf.sap.corp/api/v3
# SCI_MCP_GITHUB_BASE_URL=https://github.wdf.sap.corp/api/v3

# TLS CA bundle for GitHub Enterprise.
# github.wdf.sap.corp presents a chain signed by the internal SAP Global
# Root CA, which is NOT in the default certifi trust store. Without this
# you get: "SSLCertVerificationError: self-signed certificate in
# certificate chain". Point this at a PEM containing the SAP CA chain
# (plus the public CAs). Build one with:
#
#   CERTIFI=$(uv run python -c "import certifi; print(certifi.where())")
#   echo | openssl s_client -connect github.wdf.sap.corp:443 \
#     -servername github.wdf.sap.corp -showcerts 2>/dev/null \
#     | awk '/BEGIN CERT/,/END CERT/' > /tmp/sap-chain.pem
#   # append only the SAP intermediate + root CA certs to certifi's bundle
#   cat "$CERTIFI" /tmp/sap-chain.pem > ~/.config/sap-ca/sap-ca-bundle.pem
#
# SCI_MCP_GITHUB_CA_BUNDLE / GITHUB_CA_BUNDLE / REQUESTS_CA_BUNDLE all work.
GITHUB_CA_BUNDLE=~/.config/sap-ca/sap-ca-bundle.pem
# SCI_MCP_GITHUB_CA_BUNDLE=~/.config/sap-ca/sap-ca-bundle.pem

# Documentation repository slugs (defaults shown).
# SCI_MCP_GITHUB_DOCS_OPERATION_REPO=cc/documentation-operation
# SCI_MCP_GITHUB_DOCS_CUSTOMER_REPO=cc/documentation-customer

# -----------------------------------------------------------------------------
# SAP Hyperspace LLM Proxy — Anthropic-compatible endpoint (LLM calls)
# -----------------------------------------------------------------------------
# Used for root_cause_analysis and any other generative LLM calls.
# SCI_MCP_* prefixed vars take priority over the ambient ANTHROPIC_* vars
# set by the Claude Code CLI, allowing independent configuration per deployment.
ANTHROPIC_BASE_URL=http://localhost:6655/anthropic/
ANTHROPIC_AUTH_TOKEN=your-hyperspace-bearer-token

# MCP server overrides (take priority over ANTHROPIC_* vars above):
# SCI_MCP_ANTHROPIC_BASE_URL=http://localhost:6655/anthropic/
# SCI_MCP_ANTHROPIC_AUTH_TOKEN=your-hyperspace-bearer-token
# SCI_MCP_ANTHROPIC_MODEL=anthropic--claude-sonnet-latest
# SCI_MCP_API_TIMEOUT_MS=3000000

# -----------------------------------------------------------------------------
# SAP Hyperspace LLM Proxy — OpenAI-compatible endpoint (embeddings)
# -----------------------------------------------------------------------------
# Used for generating vector embeddings via text-embedding-3-small / -large.
HYPERSPACE_OPENAI_BASE_URL=http://localhost:6655/openai/v1
# SCI_MCP_HYPERSPACE_OPENAI_BASE_URL=http://localhost:6655/openai/v1
# SCI_MCP_EMBEDDING_MODEL=text-embedding-3-small
# SCI_MCP_EMBEDDING_DIMENSIONS=1536

# -----------------------------------------------------------------------------
# Qdrant vector database
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# SCI_MCP_QDRANT_URL=http://localhost:6333
# SCI_MCP_QDRANT_API_KEY=

# -----------------------------------------------------------------------------
# MCP server transport
# -----------------------------------------------------------------------------
# 'stdio' (default) — for use with Claude Desktop / CLI MCP clients.
# 'sse'             — for HTTP+SSE server mode (expose as a network service).
# MCP_TRANSPORT=stdio
# SCI_MCP_TRANSPORT=stdio
# SCI_MCP_HOST=0.0.0.0
# SCI_MCP_PORT=8080
