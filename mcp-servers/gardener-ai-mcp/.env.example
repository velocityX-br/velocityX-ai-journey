# =============================================================================
# gardener-ai-mcp — environment variable template
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# GitHub
# -----------------------------------------------------------------------------
# Personal access token with read:repo scope.
# GARDENER_MCP_GITHUB_TOKEN takes priority; GITHUB_TOKEN is the fallback.
GITHUB_TOKEN=your-github-pat-here
# GARDENER_MCP_GITHUB_TOKEN=your-github-pat-here

# Optional repository overrides (defaults shown).
# GITHUB_DOCS_REPO=gardener/documentation
# GITHUB_GARDENER_REPO=gardener/gardener

# GitHub API base URL.  Leave unset to target github.com (default).
# Set this ONLY when ingesting from a GitHub Enterprise instance.
# Example for SAP internal GitHub:
# GITHUB_BASE_URL=https://github.tools.sap/api/v3
# GARDENER_MCP_GITHUB_BASE_URL=https://github.tools.sap/api/v3

# -----------------------------------------------------------------------------
# SAP GitHub Enterprise (github.tools.sap) — for ingest_sap_github.py
# -----------------------------------------------------------------------------
# Separate credentials for github.tools.sap so they don't conflict with the
# GITHUB_TOKEN used for public github.com/gardener/* ingestion above.
#
# Used exclusively by:
#   scripts/ingest_sap_github.py   — batch ingest of SAP GitHub issues
#   gardener_mcp tool: cache_sap_github_content — on-demand write-through cache
#
# GITHUB_SAP_TOKEN is a PAT with read:repo scope on github.tools.sap.
# It is intentionally separate from GITHUB_TOKEN (github.com).
#
GITHUB_SAP_TOKEN=your-github-tools-sap-pat-here
# GITHUB_SAP_BASE_URL=https://github.tools.sap/api/v3   # default shown
#
# Default repositories ingested by ingest_sap_github.py when --repos is omitted:
#   kubernetes-canary/issues-canary
#   kubernetes-live/issues-live
# Override by passing --repos on the CLI — no env var needed.

# -----------------------------------------------------------------------------
# SAP Hyperspace LLM Proxy — Anthropic-compatible endpoint (LLM calls)
# -----------------------------------------------------------------------------
# Used for root_cause_analysis and any other generative LLM calls.
# GARDENER_MCP_* prefixed vars take priority over the ambient ANTHROPIC_* vars
# set by the Claude Code CLI, allowing independent configuration per deployment.
ANTHROPIC_BASE_URL=http://localhost:6655/anthropic/
ANTHROPIC_AUTH_TOKEN=your-hyperspace-bearer-token

# MCP server overrides (take priority over ANTHROPIC_* vars above):
# GARDENER_MCP_ANTHROPIC_BASE_URL=http://localhost:6655/anthropic/
# GARDENER_MCP_ANTHROPIC_AUTH_TOKEN=your-hyperspace-bearer-token
# GARDENER_MCP_ANTHROPIC_MODEL=anthropic--claude-sonnet-latest
# GARDENER_MCP_API_TIMEOUT_MS=3000000

# -----------------------------------------------------------------------------
# SAP Hyperspace LLM Proxy — OpenAI-compatible endpoint (embeddings)
# -----------------------------------------------------------------------------
# Used for generating vector embeddings via text-embedding-3-small / -large.
HYPERSPACE_OPENAI_BASE_URL=http://localhost:6655/openai/v1
# GARDENER_MCP_HYPERSPACE_OPENAI_BASE_URL=http://localhost:6655/openai/v1
# GARDENER_MCP_EMBEDDING_MODEL=text-embedding-3-small
# GARDENER_MCP_EMBEDDING_DIMENSIONS=1536

# -----------------------------------------------------------------------------
# Qdrant vector database
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# GARDENER_MCP_QDRANT_URL=http://localhost:6333
# GARDENER_MCP_QDRANT_API_KEY=

# -----------------------------------------------------------------------------
# Ingestion limits
# -----------------------------------------------------------------------------
# Maximum issues to ingest (most-recently updated first). 0 = no limit.
# INGESTION_MAX_ISSUES=1000
# GARDENER_MCP_INGESTION_MAX_ISSUES=1000

# Number of issues fetched per API page during ingestion.
# INGESTION_ISSUES_BATCH_SIZE=100
# GARDENER_MCP_INGESTION_ISSUES_BATCH_SIZE=100

# Maximum PRs to ingest (most-recently updated first). 0 = no limit.
# INGESTION_MAX_PRS=500
# GARDENER_MCP_INGESTION_MAX_PRS=500

# -----------------------------------------------------------------------------
# MCP server transport
# -----------------------------------------------------------------------------
# 'stdio' (default) — for use with Claude Desktop / CLI MCP clients.
# 'sse'             — for HTTP+SSE server mode (expose as a network service).
# MCP_TRANSPORT=stdio
# GARDENER_MCP_TRANSPORT=stdio
