# CONFLUENCE (SAP Wiki) MCP Server Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# REQUIRED CONFIGURATION
# =============================================================================

# Confluence Configuration (Required)
CONFLUENCE_BASE_URL=https://your-confluence-domain.com
CONFLUENCE_API_TOKEN=your_api_token_here

# Space Configuration - Flexible space setup:
# Single space: CONFLUENCE_SPACE_KEYS=YOUR_SPACE_KEY
# Multiple spaces: CONFLUENCE_SPACE_KEYS=SPACE1,SPACE2,SPACE3
# Legacy support: CONFLUENCE_SPACE_KEY still works for backward compatibility
CONFLUENCE_SPACE_KEYS=YOUR_SPACE_KEY

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================

# MCP Server Configuration
MCP_SERVER_NAME=sap-wiki-mcp
MCP_SERVER_VERSION=1.0.0

# Confluence API Configuration
CONFLUENCE_TIMEOUT=30000

# Optimized Cache Configuration (ETag-based caching with capacity limits)
CACHE_DIR=./cache
# Maximum number of cache files (default: 1000, set to 0 for unlimited)
CACHE_MAX_ENTRIES=1000
# Maximum disk cache size with unit support (MB, GB)
CACHE_MAX_SIZE=100MB

# Examples for different cache sizes:
# CACHE_MAX_SIZE=100MB    # 100 Megabytes (default)
# CACHE_MAX_SIZE=2GB      # 2 Gigabytes
# CACHE_MAX_SIZE=1.5GB    # 1.5 Gigabytes (decimal supported)
# CACHE_MAX_SIZE=0        # Unlimited size

# Examples for different scenarios:
# CACHE_MAX_ENTRIES=0
# CACHE_MAX_SIZE=2GB      # Unlimited files, 2GB limit
# CACHE_MAX_ENTRIES=5000
# CACHE_MAX_SIZE=0        # 5000 files, unlimited size
# CACHE_MAX_ENTRIES=0
# CACHE_MAX_SIZE=0        # Completely unlimited cache

# Logging Configuration
LOG_LEVEL=info
LOG_DIR=./logs

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================

# Uncomment for development mode
# LOG_LEVEL=debug
# AUTO_SYNC=true
